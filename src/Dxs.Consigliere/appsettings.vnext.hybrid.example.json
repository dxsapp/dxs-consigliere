{
  "VNextRuntime": {
    "CutoverMode": "vnext_default"
  },
  "Consigliere": {
    "Sources": {
      "providers": {
        "node": {
          "enabled": true,
          "enabledCapabilities": [ "broadcast", "validation_fetch" ],
          "connection": {
            "rpcUrl": "http://127.0.0.1:8332",
            "rpcUser": "bitcoin",
            "rpcPassword": "secret",
            "zmqTxUrl": "tcp://127.0.0.1:28332",
            "zmqBlockUrl": "tcp://127.0.0.1:28333"
          }
        },
        "jungleBus": {
          "enabled": true,
          "enabledCapabilities": [ "realtime_ingest", "block_backfill" ],
          "connection": {
            "baseUrl": "https://junglebus.gorillapool.io",
            "apiKey": "replace-me"
          }
        },
        "bitails": {
          "enabled": true,
          "enabledCapabilities": [ "realtime_ingest", "raw_tx_fetch", "historical_address_scan", "historical_token_scan" ],
          "connection": {
            "baseUrl": "https://api.bitails.io",
            "transport": "websocket",
            "websocket": {
              "baseUrl": "https://api.bitails.io/global"
            }
          }
        },
        "whatsonchain": { "enabled": false, "enabledCapabilities": [], "connection": {} }
      },
      "routing": {
        "preferredMode": "hybrid",
        "primarySource": "bitails",
        "fallbackSources": [ "junglebus", "node" ],
        "verificationSource": "node"
      },
      "capabilities": {
        "broadcast": {
          "mode": "multi",
          "sources": [ "node", "bitails" ],
          "fallbackSources": []
        },
        "realtime_ingest": { "source": "bitails", "fallbackSources": [ "junglebus", "node" ] },
        "block_backfill": { "source": "junglebus", "fallbackSources": [ "node" ] },
        "raw_tx_fetch": { "source": "bitails", "fallbackSources": [ "whatsonchain" ] },
        "validation_fetch": { "source": "node", "fallbackSources": [ "bitails" ] },
        "historical_address_scan": { "source": "bitails", "fallbackSources": [ "whatsonchain" ] },
        "historical_token_scan": { "source": "bitails", "fallbackSources": [] }
      }
    },
    "Storage": {
      "RawTransactionPayloads": {
        "enabled": true,
        "provider": "raven",
        "location": {
          "collection": "RawTransactionPayloads"
        },
        "compression": {
          "enabled": true,
          "algorithm": "zstd"
        }
      }
    }
  }
}
