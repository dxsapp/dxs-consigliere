{
  "VNextRuntime": {
    "CutoverMode": "vnext_default"
  },
  "Consigliere": {
    "Sources": {
      "providers": {
        "node": { "enabled": false, "enabledCapabilities": [], "connection": {} },
        "jungleBus": {
          "enabled": true,
          "enabledCapabilities": [],
          "connection": {
            "baseUrl": "https://junglebus.gorillapool.io",
            "apiKey": "replace-me"
          }
        },
        "bitails": {
          "enabled": true,
          "enabledCapabilities": [ "broadcast", "realtime_ingest", "raw_tx_fetch", "validation_fetch", "historical_address_scan", "historical_token_scan" ],
          "connection": {
            "baseUrl": "https://api.bitails.io",
            "transport": "websocket",
            "websocket": {
              "baseUrl": "https://api.bitails.io/global"
            }
          }
        },
        "whatsonchain": {
          "enabled": true,
          "enabledCapabilities": [ "raw_tx_fetch" ],
          "connection": {
            "baseUrl": "https://api.whatsonchain.com/v1/bsv/main",
            "apiKey": "replace-me"
          }
        }
      },
      "routing": {
        "preferredMode": "bitails",
        "primarySource": "bitails",
        "fallbackSources": [ "junglebus", "whatsonchain" ],
        "verificationSource": "bitails"
      },
      "capabilities": {
        "broadcast": {
          "mode": "multi",
          "sources": [ "bitails", "whatsonchain" ],
          "fallbackSources": []
        },
        "realtime_ingest": { "source": "bitails", "fallbackSources": [] },
        "raw_tx_fetch": { "source": "bitails", "fallbackSources": [ "whatsonchain" ] },
        "validation_fetch": { "source": "bitails", "fallbackSources": [ "whatsonchain" ] },
        "historical_address_scan": { "source": "bitails", "fallbackSources": [ "whatsonchain" ] },
        "historical_token_scan": { "source": "bitails", "fallbackSources": [] }
      }
    },
    "Storage": {
      "RawTransactionPayloads": {
        "enabled": true,
        "provider": "raven",
        "location": {
          "collection": "RawTransactionPayloads"
        },
        "compression": {
          "enabled": true,
          "algorithm": "gzip"
        }
      }
    }
  }
}
