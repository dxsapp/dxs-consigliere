{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Information",
        "Microsoft": "Warning",
        "TrustMargin.Api.Auth": "Debug",
        "System.Net.Http.HttpClient": "Warning",
        "Microsoft.AspNetCore.Identity": "Information",
        "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "Fatal"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss.fffzzz} [{Level:u3}] [{SourceContext:l}]{Scope:l} {Message}{NewLine}{Exception}"
        }
      }
    ]
  },
  "BackgroundTasks": {
    "DisabledTasks": [
      // fallback services, before activation edit JungleBus section
      "JungleBusSyncMissingDataBackgroundTask"
    ],
    "EnabledTasks": [
      "AppInitBackgroundTask",
      "ActualChainTipVerifyBackgroundTask",
      "BlockProcessBackgroundTask",
      "RealtimeIngestBackgroundTask",
      "StasAttributesChangeObserverTask",
      "StasAttributesMissingTransactions",
      "UnconfirmedTransactionsMonitor"
    ]
  },
  "RavenDb": {
    "Urls": ["http://localhost:8080"],
    "DbName": "Consigliere"
    // For production environment
    // "ClientCertificate": "[path to certificate].pfx",
    // "CertificatePassword": "[password for certificate if any]"
  },
  "Network": "Mainnet",
  "ScanMempoolOnStart": true,
  "BlockCountToScanOnStart": 2,
  "ZmqClient": {
    "RawTx2Address": "tcp://[BSV node address or domain]",
    "RemovedFromMempoolBlockAddress": "tcp://[BSV node address or domain]",
    "DiscardedFromMempoolAddress": "tcp://[BSV node address or domain]",
    "HashBlock2Address": "tcp://[BSV node address or domain]"
  },
  "BsvNodeApi": {
    "BaseUrl": "http://[BSV node address or domain]",
    "User": "[Bsv node rpc user]",
    "Password": "[Bsv node rpc password]"
  },
  "TransactionFilter": {
    "Addresses": [
      // If you specify a BSV address here, Consigliere will build an index for all new transactions related to this address of all output types it recognizes: P2PKH, STAS, 1SatMnee.
    ],
    "Tokens": [
      // If you specify a STAS token ID here, Consigliere will build an index for all new STAS transactions related to this STAS token.
      // Example: Dxs USDT-TON Stas token
      "542a56ec7a307fd68bf925d8f4d525ca61e868ad"
    ]
  },
  "JungleBus": {
    "Enabled": false,
    "BlockSubscriptionId": "",
    "MempoolSubscriptionId": ""
  },
  "VNextRuntime": {
    "CutoverMode": "legacy"
  },
  "Consigliere": {
    "AdminAuth": {
      "enabled": false,
      "username": "admin",
      "passwordHash": "",
      "sessionTtlMinutes": 480,
      "cookieName": "consigliere_admin"
    },
    "Sources": {
      "providers": {
        "node": {
          "enabled": false,
          "enabledCapabilities": [],
          "connection": {}
        },
        "jungleBus": {
          "enabled": false,
          "enabledCapabilities": [],
          "connection": {}
        },
        "bitails": {
          "enabled": false,
          "enabledCapabilities": [],
          "connection": {}
        },
        "whatsonchain": {
          "enabled": false,
          "enabledCapabilities": [],
          "connection": {}
        }
      },
      "routing": {
        "fallbackSources": []
      },
      "capabilities": {
        "broadcast": {
          "sources": []
        },
        "realtime_ingest": {
          "fallbackSources": []
        },
        "block_backfill": {
          "fallbackSources": []
        },
        "raw_tx_fetch": {
          "fallbackSources": []
        },
        "validation_fetch": {
          "fallbackSources": []
        }
      }
    },
    "Storage": {
      "RawTransactionPayloads": {
        "enabled": false,
        "provider": "raven",
        "location": {
          "collection": "RawTransactionPayloads"
        }
      }
    },
    "Cache": {
      "enabled": true,
      "backend": "memory",
      "maxEntries": 10000,
      "safetyTtlSeconds": 30,
      "azos": {
        "enabled": false
      }
    }
  }
}
