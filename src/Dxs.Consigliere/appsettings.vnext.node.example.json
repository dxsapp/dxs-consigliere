{
  "VNextRuntime": {
    "CutoverMode": "vnext_default"
  },
  "Consigliere": {
    "Sources": {
      "routing": {
        "preferredMode": "node",
        "primarySource": "node",
        "fallbackSources": [],
        "verificationSource": "node"
      },
      "capabilities": {
        "broadcast": {
          "mode": "single",
          "source": "node",
          "sources": [ "node" ],
          "fallbackSources": []
        },
        "realtime_ingest": { "source": "node", "fallbackSources": [] },
        "block_backfill": { "source": "node", "fallbackSources": [] },
        "raw_tx_fetch": { "source": "node", "fallbackSources": [] },
        "validation_fetch": { "source": "node", "fallbackSources": [] }
      }
    },
    "Storage": {
      "RawTransactionPayloads": {
        "enabled": true,
        "provider": "raven",
        "location": {
          "collection": "RawTransactionPayloads"
        },
        "compression": {
          "enabled": true,
          "algorithm": "zstd"
        }
      }
    }
  }
}
